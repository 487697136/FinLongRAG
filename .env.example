# Qwen / DashScope compatible APIs
DASHSCOPE_API_KEY=
FINLONGRAG_QWEN_MODEL=qwen-plus
FINLONGRAG_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# PostgreSQL 18 + local FAISS vector index
FINLONGRAG_DATABASE_URL=postgresql://finlongrag:finlongrag@localhost:5432/finlongrag
FINLONGRAG_POSTGRES_USER=finlongrag
FINLONGRAG_POSTGRES_PASSWORD=finlongrag
FINLONGRAG_POSTGRES_DB=finlongrag
FINLONGRAG_POSTGRES_PORT=5432

# Real semantic vector retrieval
FINLONGRAG_ENABLE_VECTOR_RETRIEVAL=true
FINLONGRAG_VECTOR_STORE=faiss
FINLONGRAG_VECTOR_EMBEDDING_PROVIDER=dashscope
FINLONGRAG_VECTOR_EMBEDDING_MODEL=text-embedding-v4
FINLONGRAG_VECTOR_DIMENSION=1024
FINLONGRAG_VECTOR_BATCH_SIZE=10
FINLONGRAG_BM25_CHANNEL_WEIGHT=1.0
FINLONGRAG_VECTOR_CHANNEL_WEIGHT=0.65

# Real rerank API
FINLONGRAG_RERANK_PROVIDER=dashscope
FINLONGRAG_RERANK_MODEL=qwen3-rerank
FINLONGRAG_RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
FINLONGRAG_RERANK_TOP_K_MULTIPLIER=4

# PDF parsing (opendataloader-pdf; requires Java 11+ on PATH)
# FINLONGRAG_PDF_HYBRID=docling-fast
# FINLONGRAG_PDF_HYBRID_URL=http://127.0.0.1:5002

# Optional dataset and runtime paths
FINLONGRAG_DATASET_ROOT=
FINLONGRAG_RAW_ROOT=
FINLONGRAG_QUESTIONS_ROOT=
FINLONGRAG_PROCESSED_DIR=
FINLONGRAG_INDEX_DIR=
FINLONGRAG_OUTPUT_DIR=
FINLONGRAG_OBJECT_STORAGE_ROOT=data/object_storage

# Set to false in production to disable unauthenticated /api/* legacy routes.
FINLONGRAG_ENABLE_LEGACY_API=true

# Agent runtime (engineering-oriented, not competition-tuned)
FINLONGRAG_CONDITIONAL_RERANK=true
FINLONGRAG_RERANK_TRIGGER_THRESHOLD=0.15
FINLONGRAG_QUERY_CACHE_ENABLED=true
FINLONGRAG_QUERY_CACHE_MAX_ENTRIES=256
FINLONGRAG_QUERY_CACHE_TTL_SECONDS=1800
FINLONGRAG_REQUIRE_KB_SCOPE_FOR_RAG=false

# Local development login fallback
FINLONGRAG_DEFAULT_USERNAME=admin
FINLONGRAG_DEFAULT_PASSWORD=finlongrag
FINLONGRAG_DEFAULT_EMAIL=admin@finlongrag.local
FINLONGRAG_SECRET_KEY=change-me-to-a-random-64-character-secret-before-production
